# 必填 - 小程序的登录 Cookie
SHIRO_COOKIE=shiroJID=你的cookie值

# 登录用户名和密码
LOGIN_USERNAME=admin
LOGIN_PASSWORD=你的密码

# 选填 - 企业微信群机器人 Webhook URL
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=你的key

# 选填 - 电费余额预警阈值（低于此值时发送企业微信通知，设为0或留空关闭）
ALERT_THRESHOLD=20

# 选填 - Cookie 签名密钥
COOKIE_SECRET=
